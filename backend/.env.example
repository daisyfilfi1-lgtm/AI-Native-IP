# PostgreSQL（必填）
DATABASE_URL=postgresql://user:password@localhost:5432/ip_factory

# 飞书知识库同步（可选）
# 在飞书开放平台创建应用后，将凭证填到环境变量；Railway 在 Web 服务 Variables 中配置
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 百度网盘同步（可选；也可在管理后台配置，见 docs/BAIDU_PAN.md）
# BAIDU_PAN_ACCESS_TOKEN=

# AI 服务（可选，用于自动打标、Whisper 转写、向量化等）
# 主配置：LLM + Embedding（可填 DeepSeek 等 OpenAI 兼容端点）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
EMBEDDING_MODEL=deepseek-embedding
LLM_MODEL=deepseek-chat
AUTO_TAG_ENABLED=true

# 语音转写（可选）：与主配置分离时填 OpenAI 官方 Key，Whisper 走 OpenAI
# 不填则与主 OPENAI_* 相同（全 OpenAI 或同一代理时无需单独配置）
OPENAI_TRANSCRIPTION_API_KEY=
# 仅当转写 Key 已配置且需显式指定端点时填写；留空且已填转写 Key 时默认 https://api.openai.com/v1
# OPENAI_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# WHISPER_MODEL=whisper-1

# 对象存储（S3 兼容，启用 /memory/upload 与 local_file_id 录入）
# 阿里云 OSS 示例（华东2 上海，请按控制台「Endpoint」替换地域）：
# STORAGE_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# STORAGE_REGION=cn-shanghai
# STORAGE_BUCKET=你的Bucket名
# STORAGE_ACCESS_KEY=RAM 子账号 AccessKeyId
# STORAGE_SECRET_KEY=RAM 子账号 AccessKeySecret
# STORAGE_FORCE_PATH_STYLE=true
# 若 Bucket 绑定自定义域名/CDN，可填 STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=
STORAGE_FORCE_PATH_STYLE=true

# 可选：日志级别
# LOG_LEVEL=INFO
