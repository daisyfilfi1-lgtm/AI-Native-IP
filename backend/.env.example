# PostgreSQL（必填）
DATABASE_URL=postgresql://user:password@localhost:5432/ip_factory

# Redis（RQ 后台任务，可选；不配置时 ingest 回退到 BackgroundTasks）
# REDIS_URL=redis://localhost:6379/0
# RQ 队列名（worker 与入队端要一致）
# RQ_QUEUE_NAME=ingest

# CORS：前端跨域直连本 API 时生效。默认 CORS_ORIGINS=*（勿与 CORS_ALLOW_CREDENTIALS=true 同用）。
# 仅允许指定站点时示例：CORS_ORIGINS=https://你的站点.netlify.app,http://localhost:3000
# CORS_ORIGIN_REGEX=^https://.*\\.netlify\\.app$
# CORS_ALLOW_CREDENTIALS=true

# 飞书知识库同步（可选）
# 在飞书开放平台创建应用后，将凭证填到环境变量；Railway 在 Web 服务 Variables 中配置
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 百度网盘同步（可选；也可在管理后台配置，见 docs/BAIDU_PAN.md）
# BAIDU_PAN_ACCESS_TOKEN=

# AI 服务（可选，用于自动打标、Whisper 转写、向量化等）
# 主配置：LLM + Embedding（可填 DeepSeek 等 OpenAI 兼容端点）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
EMBEDDING_MODEL=deepseek-embedding
LLM_MODEL=deepseek-chat
AUTO_TAG_ENABLED=true
# LLM / Embedding HTTP 超时（秒），防止后台 ingest 长时间挂起
# OPENAI_HTTP_TIMEOUT=120

# 录入任务资源上限（防 OOM / 进程被 Killed）：超长正文截断、分块数量上限
# INGEST_MAX_TEXT_CHARS=500000
# INGEST_MAX_CHUNKS=120
# INGEST_EMBED_BATCH_SIZE=16
# INGEST_COMMIT_EVERY=25
# URL 拉取正文最大字节（流式读取，避免超大页面撑爆内存）
# INGEST_MAX_URL_BYTES=20971520
# 仅保存文本、不写向量（排查 OOM 或极低内存实例）
# INGEST_SKIP_EMBEDDING=0
# 当 INGEST_SKIP_EMBEDDING=1 时，是否在 ingest 完成后异步补齐向量（推荐开启）
# INGEST_ASYNC_VECTOR_BACKFILL=1
# 本地 sentence-transformers / PyTorch 仅在显式开启时加载（Railway 勿开，否则 API 失败时可能误加载导致整进程 Killed）
# LOCAL_EMBEDDING_ENABLED=false

# 语音转写（可选）：与主配置分离时填 OpenAI 官方 Key，Whisper 走 OpenAI
# 不填则与主 OPENAI_* 相同（全 OpenAI 或同一代理时无需单独配置）
OPENAI_TRANSCRIPTION_API_KEY=
# 仅当转写 Key 已配置且需显式指定端点时填写；留空且已填转写 Key 时默认 https://api.openai.com/v1
# OPENAI_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# WHISPER_MODEL=whisper-1

# 对象存储（S3 兼容，启用 /memory/upload 与 local_file_id 录入）
# 未配置时自动使用本地 backend/data/uploads，便于本地开发
# 阿里云 OSS 示例（华东2 上海，请按控制台「Endpoint」填外网 Endpoint，勿用 path-style 错误）：
# STORAGE_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# STORAGE_REGION=cn-shanghai
# STORAGE_BUCKET=你的Bucket名
# STORAGE_ACCESS_KEY=RAM 子账号 AccessKeyId
# STORAGE_SECRET_KEY=RAM 子账号 AccessKeySecret
# 留空则按 Endpoint 自动选择：OSS/AWS 为 virtual-hosted；MinIO 等一般为 path-style
# 仅 MinIO/自建需显式：STORAGE_FORCE_PATH_STYLE=true
# 若 Bucket 绑定自定义域名/CDN，可填 STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
# 已配置 S3 但上传仍失败时，在未设置下一项前会自动回退写入本地目录（避免仅因 S3 报错导致 500）
# 若仅允许 S3、禁止写本地：STORAGE_LOCAL_DISABLED=true
# 自定义本地路径：STORAGE_LOCAL_PATH=./my_uploads
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=
# STORAGE_FORCE_PATH_STYLE=

# Qdrant 向量数据库（可选，启用后提升向量检索性能）
# 本地模式：QDRANT_URL=http://localhost:6333（无需api_key）
# 云端模式：QDRANT_URL=https://xxx.qdrant.cloud + QDRANT_API_KEY=your_api_key
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_cloud_api_key

# Neo4j 知识图谱（可选，启用后支持Graph RAG）
# 本地：NEO4J_URI=bolt://localhost:7687, NEO4J_PASSWORD=your_password
# Neo4j Aura：NEO4J_URI=bolt://xxx.databases.neo4j.io:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# 多模态模型（可选，用于图片/视频理解）
# 需要支持视觉的LLM模型（如GPT-4V、Claude Vision等）
# VISION_MODEL=gpt-4o
# 如果使用OpenAI官方API：
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_API_KEY=your_openai_key

# TikHub 社交媒体数据 API（可选：竞品/分享链接解析、抖音·快手·小红书等）
# 文档：https://docs.tikhub.io/  · 控制台与 Token：https://www.tikhub.io
# 请求头：Authorization: Bearer <你的 API Token>
# 大陆访问可用 https://api.tikhub.dev ，境外用 https://api.tikhub.io（路径与参数相同，仅换域名）
# TIKHUB_API_KEY=
# TIKHUB_BASE_URL=https://api.tikhub.io
# 仿写推荐：小红书话题 page_id（24 位十六进制），逗号分隔；与《竞品分析》无直接对应（该表为抖音对标），需在 App 话题页或 TikHub get_topic_info 试跑获得。说明见 docs/IP/TIKHUB_仿写推荐_对齐竞品分析.md
# TIKHUB_XHS_TOPIC_PAGE_IDS=
# 仿写推荐：额外关键词（逗号分隔），与 IP 画像字段一起参与抖音低粉榜标题匹配；已按 docs/IP知识库/竞品分析.docx 赛道推导
# TIKHUB_REMIX_EXTRA_KEYWORDS=宝妈,女性创业,副业,搞钱,私房,知识付费,女性成长,商业思维,销讲,私域,轻资产,职场,独立女性,自律,美业,转化,线下,社群,朋友圈,文案,访谈,实体,时间管理,认知,销讲女王,大课,合伙人,轻资产创业,私域变现,宝妈副业,女性力量,搞钱认知

# 抖音仿写 · 火山方舟豆包（OpenAI 兼容；二选一或同时配置后 Bot 优先）
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 推理接入点（裸 Chat /chat/completions）
# ARK_MODEL=ep-xxxx
# 应用 Bot（/bots/chat/completions），在控制台创建应用并开启联网等插件后，复制应用 ID（多为 bot-xxxx）
# ARK_BOT_ID=bot-xxxx
# REMIX_DOUYIN_ARK_BOT_FIRST=1 时优先调 Bot，失败再回退 ARK_MODEL（默认 1）
# 说明：与豆包 App 粘贴链接的体验不同——此处是「裸」Chat Completions，只传文本；App 侧常有联网/解析/插件。
# 仅靠链接而页面抓不到正文时，容易偏泛口播；需 TikHub/ASR 等先有素材，或改用方舟「应用/Bot+插件」类 API。
# 豆包路径会先合并 TikHub 元数据 + 页面摘录 + 可选 API 字段 pasted_script；素材仍不足时可设 REMIX_DOUYIN_ASR_BEFORE_DOUBAO=1 再尝试下载+ASR（慢且依赖 TikHub 与阿里云 ASR）。
# REMIX_DOUYIN_MIN_SNIPPET_FOR_ASR=40 低于此字符数才触发上述 ASR（默认 40）。
# 已配置豆包时默认不再跑 TikHub 下载+ASR / Whisper；若仍要在豆包失败后再试旧链路：REMIX_DOUYIN_TRY_LEGACY=1

# 手机号验证码登录（JWT）
# 生产环境务必设置强随机 JWT_SECRET；开发未设置时使用内置弱密钥（勿用于生产）
# JWT_SECRET=
# JWT_EXPIRE_SEC=604800
# SMS_PROVIDER=mock
# 真实短信（腾讯云）：https://console.cloud.tencent.com/smsv2
# SMS_PROVIDER=tencent
# TENCENTCLOUD_SECRET_ID=
# TENCENTCLOUD_SECRET_KEY=
# 与控制台「短信」应用 SdkAppId、签名、模板 ID 一致；模板内容通常为「您的验证码为{1}」单参数
# SMS_TENCENT_REGION=ap-guangzhou
# SMS_TENCENT_SMS_SDK_APP_ID=
# SMS_TENCENT_SIGN_NAME=
# SMS_TENCENT_TEMPLATE_ID=
# OTP_TTL_SEC=300
# OTP_RESEND_SEC=60
# OTP_PEPPER=
# 短信通道未开通时，可临时开启免短信登录（仅用于联调，生产建议关闭）
# OTP_BYPASS_ENABLED=true
# OTP_BYPASS_CODE=123456
# 非生产环境：若 DATABASE_URL 无法连接，联调码仍签发 JWT；/api/me 等依赖 JWT 内 phone 回退，无需本地 Postgres。
#
# 客户演示 / UAT（可在 Railway production 上临时开启）：任意手机号 + 任意验证码均可登录。
# 默认关闭；仅当设为 1/true/yes 时生效。测试结束后务必删除或设为 false。
# AUTH_ACCEPT_ANY_LOGIN=true

# 仿写 V2（三层迁移+校验）开关，建议灰度开启
# REMIX_V2_ENABLED=true

# 可选：日志级别
# LOG_LEVEL=INFO
