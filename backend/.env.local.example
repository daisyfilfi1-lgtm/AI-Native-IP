# 本地开发一键跑通配置
# 复制为 .env 后: 1) docker-compose up -d  2) python scripts/run_migrations.py  3) uvicorn app.main:app

# 使用 docker-compose 中的 PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ip_factory

# AI 服务（必填，用于向量化与检索）
OPENAI_API_KEY=你的Key
OPENAI_BASE_URL=https://api.deepseek.com
EMBEDDING_MODEL=deepseek-embedding
LLM_MODEL=deepseek-chat

# 对象存储：不配置时自动使用本地 backend/data/uploads
# STORAGE_LOCAL_DISABLED=false
# 如需禁用本地上传 fallback：STORAGE_LOCAL_DISABLED=true

# Qdrant：可选。不配置时 /vector/search 会降级到 PostgreSQL
# 启用本地 Qdrant: docker-compose --profile qdrant up -d
QDRANT_URL=http://localhost:6333
